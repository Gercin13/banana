# --- Nano Studio configuration ---

# REQUIRED: WaveSpeed AI API key.
# Get one at https://wavespeed.ai → Dashboard → API Keys → Generate.
# Note: a top-up is required to activate the key ($1 trial credit for new accounts).
WAVESPEED_API_KEY=your_key_here

# Optional overrides ---------------------------------------------------------
# PORT=3000
# DATA_DIR=./data

# WaveSpeed base URL (default shown):
# WAVESPEED_BASE_URL=https://api.wavespeed.ai/api/v3

# OPTIONAL: enables the "✨ Улучшить промпт" toggle (prompt enhancement via the
# Atomesus "cipher" text model). Leave unset to hide the feature entirely.
# ATOMESUS_API_KEY=atms_sk_...
