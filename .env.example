# --- Nano Studio configuration ---

# REQUIRED: Google AI Studio (Gemini) API key.
# Get one at https://aistudio.google.com  ->  "Get API key".
GEMINI_API_KEY=your_key_here

# Optional overrides ---------------------------------------------------------
# PORT=3000
# DATA_DIR=./data                     # where images + history are stored

# Model tiers (defaults shown). "draft" = fast/cheap, "quality" = best.
# GEMINI_DRAFT_MODEL=gemini-3.1-flash-image
# GEMINI_QUALITY_MODEL=gemini-3-pro-image

# Advanced:
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# GEMINI_API_VERSION=v1beta
